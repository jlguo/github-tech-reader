# GitHub Token (optional, increases rate limit)
GITHUB_TOKEN=

# LLM configuration for CrewAI agents (any OpenAI-compatible API)
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Backend settings
# DATA_DIR — absolute path to data directory (SQLite DB, etc.)
#   local dev:   leave empty (auto-detected as backend/data/)
#   container:   set to e.g. /app/data
DATA_DIR=
# Override if you want a custom database path directly
# DATABASE_URL=sqlite+aiosqlite:///data/reader.db
DEBUG=false

# CORS — allowed frontend origins (JSON array format)
#   local dev:    ["http://localhost:5173"]
#   production:   ["https://你的项目.pages.dev", "https://你的自定义域名.com"]
CORS_ORIGINS=["http://localhost:5173"]

# Server port (set automatically by Render in production, default 8000 locally)
PORT=8000
